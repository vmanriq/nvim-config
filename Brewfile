# Dependencias externas de la config de Neovim
# Uso: brew bundle --file Brewfile  (lo corre setup.sh)
brew "neovim"
brew "ripgrep"   # telescope live_grep
brew "fd"        # telescope find_files
brew "gh"        # octo.nvim (PR review) — requiere gh auth login
brew "node"      # LSPs de TS/JS (fallback si no usas nvm)
brew "stylua"    # formato Lua (conform.nvim)
brew "awscli"    # :AwsCheck / :AwsLogin
brew "make"      # build de telescope-fzf-native
brew "lazygit"   # opcional, integraciones git
